page {
  min-height: 100%;
  background: #020607;
  color: #f4efe4;
  font-family: "PingFang SC", "HarmonyOS Sans SC", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  background:
    linear-gradient(90deg, rgba(246, 234, 208, 0.018) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(246, 234, 208, 0.014) 1rpx, transparent 1rpx),
    linear-gradient(180deg, #081518 0%, #03080a 54%, #010304 100%);
  background-size: 64rpx 64rpx, 64rpx 64rpx, auto;
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.hero {
  padding: 36rpx 30rpx;
  border: 1rpx solid rgba(176, 138, 58, 0.24);
  border-radius: 16rpx;
  background: linear-gradient(145deg, rgba(8, 20, 23, 0.96), rgba(3, 8, 10, 0.92));
  box-shadow: 0 20rpx 64rpx rgba(0, 0, 0, 0.28);
}

.eyebrow {
  color: #c9bb8e;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.h1 {
  margin-top: 16rpx;
  color: #fff6de;
  font-size: 38rpx;
  line-height: 1.22;
  font-weight: 600;
}

.h2 {
  color: #fff6de;
  font-size: 30rpx;
  font-weight: 600;
}

.muted {
  color: #96978e;
  font-size: 24rpx;
  line-height: 1.6;
}

.section {
  margin-top: 34rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.card {
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid rgba(246, 234, 208, 0.08);
  border-radius: 16rpx;
  background: rgba(7, 17, 19, 0.9);
  box-shadow: 0 14rpx 44rpx rgba(0, 0, 0, 0.22);
}

.card + .card {
  margin-top: 20rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(176, 138, 58, 0.13);
  color: #ead7a2;
  font-size: 20rpx;
}

.tag.gold {
  background: rgba(246, 234, 208, 0.1);
  color: #f4e6be;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: 16rpx;
  border: 0;
  font-size: 25rpx;
  font-weight: 600;
}

.btn.primary {
  background: linear-gradient(135deg, #b08a3a, #f6eac8);
  color: #06100f;
}

.btn.gold {
  background: linear-gradient(135deg, #a77f30, #f2dc9a);
  color: #07100f;
}

.btn.ghost {
  border: 1rpx solid rgba(176, 138, 58, 0.42);
  background: transparent;
  color: #ead7a2;
}

.btn[disabled] {
  opacity: 0.46;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #d8cfb6;
  font-size: 23rpx;
}

.input,
.textarea,
.picker {
  box-sizing: border-box;
  width: 100%;
  min-height: 76rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(246, 234, 208, 0.08);
  border-radius: 14rpx;
  background: rgba(3, 9, 10, 0.72);
  color: #fff6de;
  font-size: 25rpx;
}

.textarea {
  min-height: 132rpx;
}

.divider {
  height: 1rpx;
  margin: 28rpx 0;
  background: rgba(246, 234, 208, 0.08);
}

.status-pill {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(176, 138, 58, 0.16);
  color: #ead7a2;
  font-size: 20rpx;
}

.page-state {
  padding: 42rpx 28rpx;
  text-align: center;
}

.page-state .muted {
  margin-top: 12rpx;
}

.page-state .btn {
  margin-top: 24rpx;
}

.skeleton-line {
  height: 24rpx;
  border-radius: 999rpx;
  background: rgba(246, 234, 208, 0.08);
}

.skeleton-line + .skeleton-line {
  margin-top: 18rpx;
}

.danger-text {
  color: #ffb4b4;
}

.brand-lockup {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-mark {
  position: relative;
  flex-shrink: 0;
  width: 108rpx;
  height: 108rpx;
  border: 1rpx solid rgba(176, 138, 58, 0.18);
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 30% 20%, rgba(36, 73, 66, 0.58), transparent 44%),
    linear-gradient(145deg, #081719 0%, #03090a 68%, #010303 100%);
  box-shadow: 0 18rpx 50rpx rgba(0, 0, 0, 0.3);
  overflow: hidden;
}

.brand-mark.small {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
}

.brand-symbol-inner {
  position: absolute;
  left: 0;
  top: 0;
  width: 108rpx;
  height: 108rpx;
}

.brand-mark.small .brand-symbol-inner {
  transform: scale(0.704);
  transform-origin: left top;
}

.brand-stroke {
  position: absolute;
  border-radius: 999rpx;
}

.brand-m-left {
  left: 30rpx;
  top: 31rpx;
  width: 6rpx;
  height: 50rpx;
  background: #b9964e;
}

.brand-m-down {
  left: 31rpx;
  top: 31rpx;
  width: 44rpx;
  height: 6rpx;
  background: #b9964e;
  transform: rotate(45deg);
  transform-origin: left center;
}

.brand-m-up {
  left: 61rpx;
  top: 62rpx;
  width: 40rpx;
  height: 6rpx;
  background: #b9964e;
  transform: rotate(-45deg);
  transform-origin: left center;
}

.brand-e-vert {
  left: 74rpx;
  top: 31rpx;
  width: 7rpx;
  height: 50rpx;
  background: #f7f0de;
}

.brand-e-top,
.brand-e-mid,
.brand-e-bottom {
  left: 74rpx;
  height: 7rpx;
  background: #f7f0de;
}

.brand-e-top {
  top: 31rpx;
  width: 30rpx;
}

.brand-e-mid {
  top: 53rpx;
  width: 25rpx;
}

.brand-e-bottom {
  top: 75rpx;
  width: 30rpx;
}

.brand-title {
  color: #f7eac7;
  font-family: "Songti SC", STSong, "Noto Serif CJK SC", serif;
  font-size: 34rpx;
  line-height: 1;
  letter-spacing: 7rpx;
  font-weight: 300;
}

.brand-slogan {
  margin-top: 10rpx;
  color: #bfb187;
  font-size: 18rpx;
  line-height: 1;
  letter-spacing: 5rpx;
  white-space: nowrap;
}

.brand-caption {
  color: #f7f0de;
  font-size: 17rpx;
  line-height: 1;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.brand-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 14rpx;
  border: 1rpx solid rgba(176, 138, 58, 0.24);
  border-radius: 999rpx;
  background: rgba(3, 8, 10, 0.72);
  color: #d6c894;
  font-size: 20rpx;
}
