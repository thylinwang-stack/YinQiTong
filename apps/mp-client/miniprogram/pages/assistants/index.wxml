<view class="page safe-bottom">
  <view class="section-head top">
    <view>
      <view class="eyebrow">Assistants</view>
      <view class="h2">公开商务助理资料</view>
    </view>
  </view>

  <view class="filters card">
    <picker mode="selector" range="{{cityOptions}}" bindchange="onCityChange">
      <view class="filter-item">{{filters.city || '城市'}}</view>
    </picker>
    <picker mode="selector" range="{{sceneOptions}}" bindchange="onSceneChange">
      <view class="filter-item">{{filters.scene || '场景'}}</view>
    </picker>
    <picker mode="selector" range="{{styleOptions}}" bindchange="onStyleChange">
      <view class="filter-item">{{filters.styleTag || '风格'}}</view>
    </picker>
  </view>

  <view class="result-line">
    <text>{{assistants.length}} 位符合条件</text>
    <text class="reset" bindtap="resetFilters">重置筛选</text>
  </view>

  <view class="assistant-card card" wx:for="{{assistants}}" wx:key="id" bindtap="openDetail" data-id="{{item.id}}">
    <image class="avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
    <view class="content">
      <view class="title-row">
        <view class="name">{{item.workName}}</view>
        <view class="status-pill">{{item.city}}</view>
      </view>
      <view class="muted">{{item.assistantNo}} · {{item.intro}}</view>
      <view class="tag-row">
        <view class="tag" wx:for="{{item.styleTags}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="skill-row">
        <text wx:for="{{item.businessSkills}}" wx:key="*this">{{item}}</text>
      </view>
    </view>
  </view>
</view>
