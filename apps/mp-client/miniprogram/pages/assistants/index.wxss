.top {
  margin-top: 8rpx;
}

.filters {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.filter-item {
  height: 64rpx;
  border-radius: 14rpx;
  background: rgba(5, 13, 24, 0.7);
  color: #cbd5e4;
  font-size: 22rpx;
  line-height: 64rpx;
  text-align: center;
}

.result-line {
  display: flex;
  justify-content: space-between;
  margin: 22rpx 4rpx 14rpx;
  color: #8b98aa;
  font-size: 22rpx;
}

.reset {
  color: #d8b76a;
}

.assistant-card {
  display: flex;
  gap: 18rpx;
}

.avatar {
  width: 144rpx;
  height: 188rpx;
  border-radius: 16rpx;
  background: #101d30;
}

.content {
  flex: 1;
  min-width: 0;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

.name {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.skill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
  color: #e2c77e;
  font-size: 21rpx;
}
