.header-card {
  position: relative;
}

.header-card .h1 {
  font-size: 34rpx;
}

.progress {
  position: absolute;
  right: 28rpx;
  top: 28rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(176, 138, 58, 0.14);
  color: #ead7a2;
  font-size: 22rpx;
  font-weight: 600;
}

.task-card {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(246, 234, 208, 0.08);
  border-radius: 16rpx;
  background: rgba(7, 17, 19, 0.9);
  box-shadow: 0 14rpx 44rpx rgba(0, 0, 0, 0.22);
}

.task-card.done {
  border-color: rgba(216, 183, 106, 0.36);
  background: rgba(18, 35, 33, 0.92);
}

.check {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid rgba(216, 183, 106, 0.7);
  border-radius: 50%;
  color: #e2c77e;
  font-size: 24rpx;
  font-weight: 600;
}

.task-title {
  margin-bottom: 8rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.task-body {
  flex: 1;
}

.actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.empty {
  margin-top: 80rpx;
  color: #d8cfb6;
  text-align: center;
}
