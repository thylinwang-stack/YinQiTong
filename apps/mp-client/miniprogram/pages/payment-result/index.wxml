<view class="page result-page safe-bottom">
  <view class="result-card card {{result.status}}">
    <view class="icon">{{icon}}</view>
    <view class="h1">{{title}}</view>
    <view class="muted message">{{result.message}}</view>
    <view class="order-no" wx:if="{{result.orderNo}}">订单号：{{result.orderNo}}</view>
    <view class="actions">
      <button class="btn gold" bindtap="goOrders">查看订单</button>
      <button class="btn ghost" bindtap="goHome">返回首页</button>
    </view>
  </view>
</view>
