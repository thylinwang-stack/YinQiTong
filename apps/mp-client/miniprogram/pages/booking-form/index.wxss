.top {
  margin-top: 8rpx;
}

.stepper {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 20rpx 0 18rpx;
}

.step-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 58rpx;
  border: 1rpx solid rgba(246, 234, 208, 0.08);
  border-radius: 14rpx;
  background: rgba(8, 17, 30, 0.72);
  color: #8b98aa;
  font-size: 22rpx;
}

.step-dot.active {
  border-color: rgba(216, 183, 106, 0.36);
  color: #f1d991;
}

.step-index {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: rgba(246, 234, 208, 0.08);
  line-height: 30rpx;
  text-align: center;
  font-size: 18rpx;
}

.step-dot.active .step-index {
  background: rgba(216, 183, 106, 0.22);
}

.form-card {
  margin-top: 18rpx;
}

.form-section-title {
  margin-bottom: 22rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.field-hint {
  margin-top: 10rpx;
  color: #718096;
  font-size: 21rpx;
  line-height: 1.5;
}

.compact-textarea {
  min-height: 112rpx;
}

.notice {
  margin: 20rpx 0 126rpx;
  border-color: rgba(216, 183, 106, 0.2);
}

.notice-title {
  margin-bottom: 10rpx;
  color: #e2c77e;
  font-size: 25rpx;
  font-weight: 600;
}

.form-actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.form-actions .wide {
  grid-column: 1 / -1;
}
