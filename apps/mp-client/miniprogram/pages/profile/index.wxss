.profile-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.profile-brand-title {
  margin-bottom: 10rpx;
  font-size: 30rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(246, 234, 208, 0.08);
  color: #ffffff;
  font-size: 25rpx;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-item text:last-child {
  color: #8b98aa;
}

.section.card .muted {
  margin-top: 18rpx;
}
