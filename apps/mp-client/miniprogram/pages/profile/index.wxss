.profile-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #2a83ff, #d8b76a);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 25rpx;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-item text:last-child {
  color: #8b98aa;
}
