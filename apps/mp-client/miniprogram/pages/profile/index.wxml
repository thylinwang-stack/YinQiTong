<view class="page safe-bottom">
  <view class="profile-card card">
    <view class="avatar">商</view>
    <view>
      <view class="h2">{{userName}}</view>
      <view class="muted">{{isLoggedIn ? '已登录，可查看订单、支付状态与服务记录' : '微信登录后可查看订单、支付状态与服务记录'}}</view>
    </view>
  </view>

  <button class="btn gold section" wx:if="{{!isLoggedIn}}" bindtap="login">微信一键登录</button>

  <view class="section card">
    <view class="menu-item" bindtap="goOrders">
      <text>我的订单</text>
      <text>›</text>
    </view>
    <view class="menu-item" bindtap="goBooking">
      <text>提交饭局需求</text>
      <text>›</text>
    </view>
    <view class="menu-item" bindtap="goStaffBrief">
      <text>员工端餐前 Brief</text>
      <text>›</text>
    </view>
    <view class="menu-item" bindtap="goPolicy" data-tab="service">
      <text>服务协议</text>
      <text>›</text>
    </view>
    <view class="menu-item" bindtap="goPolicy" data-tab="privacy">
      <text>隐私政策</text>
      <text>›</text>
    </view>
  </view>

  <view class="section card">
    <view class="h2">合规承诺</view>
    <view class="muted">公开资料仅展示编号、工作名、城市、风格标签与商务能力；支付对象统一为平台服务预约金或服务费。</view>
  </view>
</view>
