.hero-copy {
  margin-top: 18rpx;
  color: #b9c5d6;
  font-size: 25rpx;
  line-height: 1.62;
}

.hero-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 30rpx;
}

.link {
  color: #d8b76a;
  font-size: 24rpx;
}

.scene-scroll {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
}

.scene-mini {
  flex: 0 0 388rpx;
  padding: 0;
  overflow: hidden;
}

.scene-cover {
  width: 100%;
  height: 176rpx;
}

.scene-name {
  padding: 18rpx 20rpx 6rpx;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 600;
}

.clamp {
  padding: 0 20rpx 20rpx;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.assistant-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: #101d30;
}

.assistant-info {
  flex: 1;
  min-width: 0;
}

.assistant-title {
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 600;
}

.compact {
  margin-top: 12rpx;
}

.compact .tag {
  padding: 7rpx 12rpx;
}

.compliance {
  border-color: rgba(216, 183, 106, 0.22);
}
