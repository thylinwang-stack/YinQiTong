.home-hero {
  position: relative;
  min-height: 620rpx;
  padding: 0;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  border-color: rgba(176, 138, 58, 0.32);
  background: #03080a;
}

.hero-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.hero-shade {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(2, 5, 6, 0.02) 0%, rgba(2, 5, 6, 0.28) 42%, rgba(2, 5, 6, 0.96) 100%),
    linear-gradient(90deg, rgba(2, 5, 6, 0.9) 0%, rgba(2, 5, 6, 0.48) 48%, rgba(2, 5, 6, 0.1) 100%);
}

.hero-content {
  position: relative;
  z-index: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 176rpx 30rpx 32rpx;
}

.home-hero .h1 {
  max-width: 430rpx;
}

.hero-brand {
  margin-bottom: 28rpx;
}

.hero-eyebrow {
  color: #d6c894;
}

.hero-copy {
  margin-top: 18rpx;
  max-width: 430rpx;
  color: #ded7c2;
  font-size: 24rpx;
  line-height: 1.62;
}

.hero-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 30rpx;
}

.link {
  color: #c9a85c;
  font-size: 24rpx;
}

.scene-scroll {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
}

.scene-mini {
  flex: 0 0 388rpx;
  padding: 0;
  overflow: hidden;
}

.scene-cover {
  width: 100%;
  height: 176rpx;
}

.scene-name {
  padding: 18rpx 20rpx 6rpx;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 600;
}

.clamp {
  padding: 0 20rpx 20rpx;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.assistant-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: #071316;
}

.assistant-info {
  flex: 1;
  min-width: 0;
}

.assistant-title {
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 600;
}

.compact {
  margin-top: 12rpx;
}

.compact .tag {
  padding: 7rpx 12rpx;
}

.compliance {
  border-color: rgba(176, 138, 58, 0.28);
}

.compliance .muted {
  margin-top: 18rpx;
}
