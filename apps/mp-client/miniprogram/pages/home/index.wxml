<view class="page safe-bottom">
  <view class="hero home-hero">
    <image class="hero-image" src="/assets/images/home-concierge-hero.jpg" mode="aspectFill" />
    <view class="hero-shade"></view>
    <view class="hero-content">
      <view class="brand-lockup hero-brand">
        <view class="brand-mark">
          <view class="brand-symbol-inner">
            <view class="brand-stroke brand-m-left"></view>
            <view class="brand-stroke brand-m-down"></view>
            <view class="brand-stroke brand-m-up"></view>
            <view class="brand-stroke brand-e-vert"></view>
            <view class="brand-stroke brand-e-top"></view>
            <view class="brand-stroke brand-e-mid"></view>
            <view class="brand-stroke brand-e-bottom"></view>
          </view>
        </view>
        <view>
          <view class="brand-title">有个饭局</view>
          <view class="brand-slogan">体面饭局 自然发生</view>
        </view>
      </view>
      <view class="eyebrow hero-eyebrow">MEET · EAT</view>
      <view class="h1">高净值人情场，得体有人照应</view>
      <view class="hero-copy">以餐前 brief、礼宾接待与现场氛围协同，让重要会面更自然、更体面、更有分寸。</view>
      <view class="hero-actions">
        <button class="btn gold" bindtap="goBooking">提交需求</button>
        <button class="btn ghost" bindtap="goAssistants">查看助理</button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="h2">核心场景</view>
      <view class="link" bindtap="goScenes">全部</view>
    </view>
    <view class="scene-scroll">
      <view class="scene-mini card" wx:for="{{scenes}}" wx:key="id" bindtap="openScene" data-id="{{item.id}}">
        <image class="scene-cover" src="{{item.cover}}" mode="aspectFill" />
        <view class="scene-name">{{item.name}}</view>
        <view class="muted clamp">{{item.summary}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="h2">商务助理</view>
      <view class="link" bindtap="goAssistants">筛选</view>
    </view>
    <view class="assistant-card card" wx:for="{{assistants}}" wx:key="id" bindtap="openAssistant" data-id="{{item.id}}">
      <image class="avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
      <view class="assistant-info">
        <view class="assistant-title">{{item.workName}} · {{item.city}}</view>
        <view class="muted">{{item.assistantNo}}</view>
        <view class="tag-row compact">
          <view class="tag" wx:for="{{item.styleTags}}" wx:key="*this">{{item}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section compliance card">
    <view class="brand-chip">有个饭局 · 合规服务边界</view>
    <view class="muted">平台仅提供正规商务社交氛围协同、餐前准备与礼宾接待服务。所有沟通通过平台客服或受控消息系统完成。</view>
  </view>
</view>
