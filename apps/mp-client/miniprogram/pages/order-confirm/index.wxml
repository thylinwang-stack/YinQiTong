<view class="page safe-bottom">
  <view class="section-head top">
    <view class="brand-lockup">
      <view class="brand-mark small">
        <view class="brand-symbol-inner">
          <view class="brand-stroke brand-m-left"></view>
          <view class="brand-stroke brand-m-down"></view>
          <view class="brand-stroke brand-m-up"></view>
          <view class="brand-stroke brand-e-vert"></view>
          <view class="brand-stroke brand-e-top"></view>
          <view class="brand-stroke brand-e-mid"></view>
          <view class="brand-stroke brand-e-bottom"></view>
        </view>
      </view>
      <view>
        <view class="eyebrow">MEET · EAT</view>
        <view class="brand-title confirm-brand-title">有个饭局</view>
      </view>
    </view>
    <view class="edit-link" bindtap="editBooking">修改</view>
  </view>

  <view class="card" wx:if="{{form}}">
    <view class="h2">需求摘要</view>
    <view class="summary-row">
      <text>城市/时间</text>
      <text>{{form.city}} · {{form.date}} {{form.time}}</text>
    </view>
    <view class="summary-row">
      <text>饭局类型</text>
      <text>{{form.dinnerType}}</text>
    </view>
    <view class="summary-row">
      <text>人数配置</text>
      <text>{{form.guestCount}} 位嘉宾 · {{form.assistantCount}} 位助理</text>
    </view>
    <view class="summary-row">
      <text>预算</text>
      <text class="gold-text">¥{{form.budget}}</text>
    </view>
    <view class="divider"></view>
    <view class="summary-block">
      <view class="block-title">饭局目标</view>
      <view class="muted">{{form.banquetGoal || '未填写'}}</view>
    </view>
    <view class="summary-block">
      <view class="block-title">嘉宾背景</view>
      <view class="muted">{{form.guestProfile || '未填写'}}</view>
    </view>
    <view class="summary-block">
      <view class="block-title">联系人</view>
      <view class="muted">{{form.contactName || '-'}} · {{form.contactPhone || '-'}}</view>
    </view>
  </view>

  <view class="card section">
    <view class="h2">服务偏好</view>
    <view class="summary-row">
      <text>助理风格</text>
      <text>{{form.preferredAssistantStyle || '待客服确认'}}</text>
    </view>
    <view class="summary-row">
      <text>隐私级别</text>
      <text>{{form.privacyLevel || '普通商务信息'}}</text>
    </view>
    <view class="summary-row">
      <text>着装/语言</text>
      <text>{{form.dressCode || '待确认'}} · {{form.languageRequirement || '中文'}}</text>
    </view>
    <view class="summary-block" wx:if="{{form.arrivalPlan}}">
      <view class="block-title">到场安排</view>
      <view class="muted">{{form.arrivalPlan}}</view>
    </view>
  </view>

  <view class="card section" wx:if="{{selectedPackage}}">
    <view class="h2">已选套餐</view>
    <view class="package-name">{{selectedPackage.name}}</view>
    <view class="muted">{{selectedPackage.subtitle}}</view>
    <view class="price-panel">
      <view>
        <view class="metric-value">¥{{selectedPackage.depositAmount}}</view>
        <view class="metric-label">本次支付预约金</view>
      </view>
      <view>
        <view class="metric-value">¥{{selectedPackage.serviceFee}}</view>
        <view class="metric-label">预计服务费</view>
      </view>
    </view>
  </view>

  <view class="card section" wx:else>
    <view class="h2">费用预估</view>
    <view class="muted">未选择固定套餐，平台会根据需求确认最终方案。</view>
    <view class="price-panel">
      <view>
        <view class="metric-value">¥{{estimatedDeposit}}</view>
        <view class="metric-label">本次预计预约金</view>
      </view>
      <view>
        <view class="metric-value">¥{{form.budget}}</view>
        <view class="metric-label">需求预算</view>
      </view>
    </view>
  </view>

  <view class="card section boundary-card">
    <view class="brand-chip">有个饭局 · 服务确认</view>
    <view class="boundary-text">
      平台仅提供商务社交氛围协同、餐前准备与礼宾接待服务；不提供任何越界内容，不展示或交换助理私人联系方式；客户与助理沟通通过平台客服或受控消息系统完成。
    </view>
    <checkbox-group bindchange="onConfirmationChange">
      <label class="checkbox-line">
        <checkbox value="boundary" checked="{{checks.boundary}}" color="#D8B76A" />
        <text>我已阅读并确认服务边界协议</text>
      </label>
      <label class="checkbox-line">
        <checkbox value="privacy" checked="{{checks.privacy}}" color="#D8B76A" />
        <text>我同意平台为履约目的处理本次需求信息</text>
      </label>
      <label class="checkbox-line">
        <checkbox value="platformContact" checked="{{checks.platformContact}}" color="#D8B76A" />
        <text>我确认沟通、支付和服务确认均通过平台完成</text>
      </label>
    </checkbox-group>
    <view class="policy-link" bindtap="goPolicy">查看完整服务协议与隐私政策</view>
  </view>

  <button class="btn gold submit" loading="{{paying}}" disabled="{{paying}}" bindtap="pay">
    {{paying ? '正在拉起支付' : '确认并支付预约金'}}
  </button>
</view>
