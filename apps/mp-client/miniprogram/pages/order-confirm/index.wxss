.top {
  margin-top: 8rpx;
}

.confirm-brand-title {
  margin-top: 8rpx;
  font-size: 28rpx;
}

.edit-link {
  color: #d8b76a;
  font-size: 24rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 22rpx;
  padding: 14rpx 0;
  color: #cbd5e4;
  font-size: 24rpx;
}

.summary-row text:last-child {
  color: #ffffff;
  text-align: right;
}

.gold-text,
.summary-row.strong text:last-child {
  color: #e2c77e;
  font-weight: 700;
}

.package-name {
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.summary-block {
  margin-top: 18rpx;
}

.block-title {
  margin-bottom: 8rpx;
  color: #cbd5e4;
  font-size: 22rpx;
}

.price-panel {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.price-panel > view {
  padding: 18rpx;
  border-radius: 14rpx;
  background: rgba(5, 13, 24, 0.64);
}

.metric-value {
  color: #e2c77e;
  font-size: 28rpx;
  font-weight: 700;
}

.metric-label {
  margin-top: 8rpx;
  color: #8b98aa;
  font-size: 21rpx;
}

.boundary-card {
  margin-bottom: 126rpx;
}

.boundary-text {
  margin: 14rpx 0 20rpx;
  color: #b9c5d6;
  font-size: 24rpx;
  line-height: 1.7;
}

.checkbox-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 24rpx;
}

.policy-link {
  margin-top: 18rpx;
  color: #d8b76a;
  font-size: 24rpx;
}

.submit {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
}
