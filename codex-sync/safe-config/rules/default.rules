prefix_rule(pattern=["curl", "-L"], decision="allow")
prefix_rule(pattern=["cp", "-R", "/private/tmp/VSCode-install/Visual", "Studio", "Code.app", "/Applications/"], decision="allow")
prefix_rule(pattern=["cp", "-R", "/private/tmp/VSCode-install/Visual Studio Code.app", "/Applications/"], decision="allow")
prefix_rule(pattern=["ln", "-sf"], decision="allow")
prefix_rule(pattern=["sudo", "-n", "ln", "-sf", "/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code", "/usr/local/bin/code"], decision="allow")
prefix_rule(pattern=["mkdir", "-p"], decision="allow")
prefix_rule(pattern=["git", "init"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "rm", "-r", "--cached", "--ignore-unmatch"], decision="allow")
